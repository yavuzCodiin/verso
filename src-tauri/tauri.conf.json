{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Verso",
  "version": "0.2.1",
  "identifier": "com.verso.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Verso",
        "width": 1340,
        "height": 860,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https: data:; media-src 'self' https:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; frame-src https://player.vimeo.com https://w.soundcloud.com https://open.spotify.com https://player.twitch.tv; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEzNTQyNzZERDFGNTNEQUQKUldTdFBmWFJiU2RVRXpkTFRrbnZSTEx1SlhvdUtpa2ZhKzExbkdySE1iMTQ5aTR5TzlMM09Eai8K",
      "endpoints": [
        "https://github.com/yavuzCodiin/verso/releases/latest/download/latest.json"
      ]
    }
  }
}
